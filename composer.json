{
    "name": "flytachi/winter-thread",
    "description": "Object-oriented background process control for PHP — a Java-like threading model over OS processes.",
    "type": "library",
    "keywords": [
        "thread",
        "threads",
        "process",
        "process-control",
        "background",
        "background-jobs",
        "parallel",
        "concurrency",
        "proc_open",
        "posix",
        "pcntl",
        "signals",
        "worker",
        "swoole"
    ],
    "license": "MIT",
    "homepage": "https://winterframe.net",
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-detail": "vendor/bin/phpunit --testdox"
    },
    "support": {
        "issues": "https://github.com/flytachi/winter-thread/issues",
        "source": "https://github.com/flytachi/winter-thread",
        "docs": "https://winterframe.net/packages/thread"
    },
    "autoload": {
        "psr-4": {
            "Flytachi\\Winter\\Thread\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flytachi\\Winter\\Thread\\Tests\\": "tests/"
        }
    },
    "bin": ["wExecutor"],
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "opis/closure": "^4.5"
    },
    "suggest": {
        "ext-shmop": "Required for Thread::PAYLOAD_SHM mode (Swoole-compatible shared memory payload delivery)"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "squizlabs/php_codesniffer": "@stable"
    },
    "authors": [
        {
            "name": "Flytachi",
            "email": "jasur.rakhmatov03@gmail.com"
        }
    ]
}
